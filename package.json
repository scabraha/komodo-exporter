{
  "name": "komodo-exporter",
  "version": "0.2.0",
  "description": "Prometheus exporter for the Komodo deployment platform",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "komodo-exporter": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --import tsx --watch src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "komodo_client": "^2.1.1",
    "pino": "^10.0.0",
    "pino-pretty": "^13.0.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.9.0",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.59.3",
    "vitest": "^3.2.4"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/scabraha/komodo-exporter.git"
  }
}
